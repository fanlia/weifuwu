{
  "name": "@weifuwujs/components",
  "version": "0.1.0",
  "type": "module",
  "description": "UI components for weifuwu — 32 composable components built on weifuwu/client primitives",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "node scripts/build.mjs",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "weifuwu": ">=0.33.0"
  },
  "devDependencies": {
    "esbuild": ">=0.19.0",
    "typescript": ">=5.0.0",
    "weifuwu": ">=0.33.0"
  },
  "keywords": ["weifuwu", "ui", "components", "signals", "jsx"],
  "license": "MIT"
}
