{
  "name": "weifuwu",
  "type": "module",
  "version": "0.33.9",
  "description": "AI SaaS framework — (req, ctx) => Response",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "default": "./dist/client/index.js"
    },
    "./client/jsx-runtime": {
      "types": "./dist/client/index.d.ts",
      "default": "./dist/client/index.js"
    }
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "prepublishOnly": "npm run build && tsc --emitDeclarationOnly --outdir dist",
    "typecheck": "tsc --noEmit",
    "pretest": "docker compose up -d --wait 2>/dev/null; sleep 1",
    "test": "node --env-file=.env --test 'src/test/**/*.test.ts'",
    "release": "node scripts/release.mjs",
    "release:dry": "node scripts/release.mjs --dry-run"
  },
  "dependencies": {
    "@ai-sdk/openai": "^4.0.15",
    "@graphql-tools/schema": "^10",
    "@tailwindcss/postcss": "^4.3.3",
    "ai": "^7.0.14",
    "graphql": "^16",
    "ioredis": "^5.11.0",
    "postcss": "^8.5.19",
    "postgres": "^3.4.9",
    "tailwindcss": "^4.3.3",
    "ws": "^8"
  },
  "devDependencies": {
    "@types/node": "^25",
    "@types/ws": "^8",
    "esbuild": "^0.28.1",
    "jsdom": "^29.1.1"
  },
  "sideEffects": false
}
