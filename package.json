{
  "name": "weifuwu",
  "type": "module",
  "version": "0.33.0",
  "description": "Web-standard HTTP microframework for Node.js — (req, ctx) => Response",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "default": "./dist/react/index.js"
    },
    "./react/client": {
      "types": "./dist/react/client.d.ts",
      "default": "./dist/react/client.js"
    }
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "prepublishOnly": "npm run build && tsc --emitDeclarationOnly --outdir dist",
    "typecheck": "tsc --noEmit",
    "pretest": "docker compose up -d --wait 2>/dev/null; sleep 1",
    "test": "node --env-file=.env --test 'src/test/**/*.test.ts'",
    "release": "node scripts/release.mjs",
    "release:dry": "node scripts/release.mjs --dry-run"
  },
  "dependencies": {
    "@graphql-tools/schema": "^10",
    "ai": "^7.0.14",
    "graphql": "^16",
    "ioredis": "^5.11.0",
    "postgres": "^3.4.9",
    "ws": "^8"
  },
  "peerDependencies": {
    "@tailwindcss/node": "^4",
    "esbuild": "^0.28",
    "react": "19",
    "react-dom": "19",
    "tailwindcss": "^4"
  },
  "peerDependenciesMeta": {
    "@tailwindcss/node": {
      "optional": true
    },
    "esbuild": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "tailwindcss": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/node": "^4.3.2",
    "@types/node": "^25",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8",
    "esbuild": "^0.28.1",
    "globals": "^17.7.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.2",
    "typescript-eslint": "^8.62.1"
  },
  "sideEffects": false
}
