{
  "name": "weifuwu",
  "type": "module",
  "version": "0.27.25",
  "description": "Web-standard HTTP microframework for Node.js — (req, ctx) => Response",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "weifuwu": "./dist/cli.js"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "prepublishOnly": "npm run build && tsc --emitDeclarationOnly --outdir dist",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint --ext .ts .",
    "test": "node --test 'test/**/*.test.ts'",
    "test:coverage": "node --experimental-test-coverage --test 'test/**/*.test.ts'",
    "test:quick": "bash scripts/test-quick.sh",
    "prepare": "husky"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.66",
    "@graphql-tools/schema": "^10",
    "@tailwindcss/postcss": "^4",
    "ai": "^6",
    "alpinejs": "^3",
    "graphql": "^16",
    "htmx.org": "^2",
    "ioredis": "^5.11.0",
    "postcss": "^8",
    "postcss-nesting": "^14.0.0",
    "postgres": "^3.4.9",
    "tailwindcss": "^4",
    "ws": "^8",
    "zod": "^4.4.3"
  },
  "lint-staged": {
    "*.ts": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.3",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "typescript-eslint": "^8.61.0"
  }
}
