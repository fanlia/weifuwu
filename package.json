{
  "name": "weifuwu",
  "type": "module",
  "version": "0.27.2",
  "description": "Web-standard HTTP microframework for Node.js — (req, ctx) => Response",
  "exports": {
    ".": "./index.ts"
  },
  "files": [
    "*.ts",
    "core/*.ts",
    "middleware/*.ts",
    "ai/*.ts",
    "postgres/*.ts",
    "postgres/**/*.ts",
    "queue/*.ts",
    "redis/*.ts"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint --ext .ts .",
    "test": "node --test 'test/**/*.test.ts'",
    "test:coverage": "node --experimental-test-coverage --test 'test/**/*.test.ts'",
    "test:quick": "bash scripts/test-quick.sh",
    "prepare": "husky"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.66",
    "@graphql-tools/schema": "^10",
    "ai": "^6",
    "graphql": "^16",
    "ioredis": "^5.11.0",
    "nodemailer": "^8.0.10",
    "postgres": "^3.4.9",
    "ws": "^8",
    "zod": "^4.4.3"
  },
  "lint-staged": {
    "*.ts": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.3",
    "@types/nodemailer": "^6.4.17",
    "@types/ws": "^8.18.1",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "typescript-eslint": "^8.61.0"
  }
}
