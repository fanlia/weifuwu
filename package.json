{
  "name": "weifuwu",
  "version": "0.23.1",
  "description": "Web-standard HTTP framework for Node.js — (req, ctx) => Response",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./react": "./dist/react.js"
  },
  "bin": {
    "weifuwu": "dist/cli.js"
  },
  "files": [
    "dist/",
    "cli.ts",
    "cli/template/",
    "opencode/ui/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "cd cli/template && NODE_ENV=development node --watch index.ts",
    "start": "cd cli/template && node index.ts",
    "build": "esbuild index.ts --bundle --format=esm --platform=node --outfile=dist/index.js --packages=external && esbuild cli.ts --bundle --format=esm --platform=node --outfile=dist/cli.js --packages=external && esbuild react.ts --bundle --format=esm --outfile=dist/react.js --external:react --external:react-dom",
    "prepublishOnly": "npm run build && tsc --emitDeclarationOnly --outdir dist",
    "test": "node --test 'test/**/*.test.ts'"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.66",
    "@aws-sdk/client-s3": "^3.1068.0",
    "@aws-sdk/s3-request-presigner": "^3.1068.0",
    "@graphql-tools/schema": "^10",
    "@tailwindcss/postcss": "^4",
    "ai": "^6",
    "chokidar": "^5.0.0",
    "esbuild": "^0.28.0",
    "graphql": "^16",
    "ioredis": "^5.11.0",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.10",
    "postgres": "^3.4.9",
    "react": "^19",
    "react-dom": "^19",
    "ws": "^8",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "type": "module",
  "license": "MIT",
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.0.0",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "typescript": "^6.0.3"
  }
}
