{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "allowImportingTsExtensions": true
  },
  "include": ["*.ts", "workflow/*.ts", "postgres/*.ts", "redis/*.ts", "queue/*.ts", "user/*.ts", "tenant/*.ts", "agent/*.ts", "messager/*.ts"]
}
