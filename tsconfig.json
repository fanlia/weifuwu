{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "allowImportingTsExtensions": true
  },
  "include": [
    "*.ts",
    "postgres/*.ts",
    "postgres/**/*.ts",
    "redis/*.ts",
    "queue/*.ts",
    "user/*.ts",
    "tenant/*.ts",
    "agent/*.ts",
    "agent/**/*.ts",
    "messager/*.ts",
    "messager/**/*.ts",
    "deploy/*.ts",
    "opencode/*.ts",
    "opencode/**/*.ts",
    "iii/*.ts",
    "iii/**/*.ts",
    "kb/*.ts",
    "cli/*.ts",
    "logdb/*.ts",
    "notifier/*.ts"
  ]
}
