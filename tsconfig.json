{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noImplicitAny": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "jsx": "react-jsx",
    "jsxImportSource": "weifuwu/client",
    "types": [
      "node"
    ],
    "rootDir": "src",
    "outDir": "dist"
  },
  "include": [
    "src/*.ts",
    "src/core/*.ts",
    "src/middleware/*.ts",
    "src/postgres/*.ts",
    "src/redis/*.ts",
    "src/graphql.ts",
    "src/types.ts",
    "src/client/*.ts",
    "src/client/**/*.ts",
    "src/ui/*.ts"
  ]
}
